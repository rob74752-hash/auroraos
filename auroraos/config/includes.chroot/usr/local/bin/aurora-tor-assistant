#!/bin/sh
# =============================================================================
# AuroraOS — Tor connection assistant (shown at login in Tor mode)
# =============================================================================
# In Tor mode the kill-switch is already up (fail-closed) from early boot, so
# NOTHING reaches the network except the Tor daemon's own connections — including
# to any bridge you configure. Tor is deliberately NOT auto-started, so you can
# choose to connect directly or set up a bridge first (useful where Tor is
# censored). This dialog drives that choice, bootstraps the SYSTEM tor, and opens
# Tor Browser once a circuit is established.
#
# BRIDGES (Tails-style): you provide bridge lines two ways — paste them as text,
# or SCAN A QR CODE with the webcam (e.g. the QR in the reply from
# bridges@torproject.org). Either way the lines land in the "Configure a bridge"
# box and go through aurora-tor-set-bridges (root, via sudo), which strictly
# validates each line and runs `tor --verify-config` before installing them. The
# QR is just another way to type a bridge line — it carries no extra trust. The
# webcam is OFF by default; the scanner turns it on only for the scan and off
# again right after. The kill-switch stays up the whole time, so nothing leaks
# while you configure. Bridges are amnesic — gone on reboot — like Tails. Keep
# your lines in a text file in ~/Persistent.
#
# Cancelling leaves the machine OFFLINE (everything stays blocked) — never a
# leak. You can reopen this from the app grid ("Connect to Tor") at any time.
# =============================================================================

# Only act in Tor mode; in other modes this is a no-op.
[ "$(cat /run/aurora-mode 2>/dev/null)" = tor ] || exit 0

SOCKS="127.0.0.1:9050"
ZEN="zenity"
BRIDGES_URL="https://bridges.torproject.org"

# Is a Tor circuit usable right now?
connected() {
    curl -s --max-time 4 --socks5-hostname "$SOCKS" \
         https://check.torproject.org/ >/dev/null 2>&1
}

open_browser() { exec /usr/local/bin/tor-browser; }

# Turn Tor's JSON-array bridge format into plain bridge lines (one per line).
# bridges.torproject.org and the bridges@torproject.org QR code commonly hand you
#   ["webtunnel [2001:db8::1]:443 <FP> url=https://h/p ver=0.0.4", "obfs4 1.2.3.4:443 ..."]
# A real bridge line never contains a double-quote, so each "..." is exactly one
# bridge line; we emit those verbatim (un-escaping JSON \/ in url= values) and
# drop only the outer array punctuation — an IPv6 [...] inside a line survives.
# Input that contains no double-quote isn't JSON and is passed through unchanged.
extract_bridge_lines() {
    if printf '%s' "$1" | grep -q '"'; then
        # Each "..." is one bridge line: strip the surrounding quotes, then delete
        # any backslashes (bridge lines never contain one, so this safely turns a
        # JSON-escaped \/ back into /). The IPv6 [...] inside a line is untouched.
        _out="$(printf '%s' "$1" | grep -oE '"[^"]*"' | sed 's/^"//; s/"$//' | tr -d '\\')"
        [ -n "$_out" ] && { printf '%s\n' "$_out"; return; }
    fi
    printf '%s' "$1"
}

# Already connected (assistant re-run after a successful connect) -> just browse.
connected && open_browser

# Wait for the GNOME Initial Setup wizard (language -> keyboard -> Wi-Fi) to
# finish before we take over the screen. This makes the connection assistant read
# as the NEXT step after the wizard, instead of popping up on top of it. We give
# the wizard a few seconds to appear (so a fast autologin doesn't race past it),
# then wait until the user finishes or closes it. If the wizard never runs
# (already completed), this falls through immediately. A ~10-min safety cap means
# a stuck wizard can never wedge the assistant forever.
#
# NOTE: pgrep -f (match the full command line), NOT -x: the kernel truncates the
# process "comm" to 15 chars, so an exact match on the 22-char name would never
# fire and the wait would silently no-op.
if command -v pgrep >/dev/null 2>&1; then
    j=0
    while [ "$j" -lt 8 ] && ! pgrep -f gnome-initial-setup >/dev/null 2>&1; do
        sleep 1; j=$((j + 1))
    done
    j=0
    while pgrep -f gnome-initial-setup >/dev/null 2>&1 && [ "$j" -lt 600 ]; do
        sleep 1; j=$((j + 1))
    done
fi

# If the GUI toolkit is somehow unavailable, connect directly rather than
# stranding the user offline with no way forward (still fail-closed underneath).
if ! command -v "$ZEN" >/dev/null 2>&1; then
    sudo aurora-tor-connect || true
    connected && open_browser
    exit 0
fi

INTRO="AuroraOS is in Tor mode.\n\nAll internet traffic is BLOCKED until you connect to Tor. Only Tor itself — and any bridge you configure — is allowed out, so your real IP cannot leak.\n\nHow would you like to connect?"

# --- Tails-style in-session bridge configuration ------------------------------
# The live user pastes bridge lines here; aurora-tor-set-bridges (root, via sudo)
# strictly validates each line and runs `tor --verify-config` before installing
# them. Empty input clears any previous bridge (connect direct). Cancel backs out
# without touching Tor. See SECURITY-AUDIT.md (C1d/C3 resolved, Tails model) for
# the accepted tradeoff.
configure_bridge() {
    # $1: optional file whose contents PRE-FILL the editable box (used by the QR
    # scanner to show the decoded lines for review). Defaults to /dev/null, i.e.
    # the box starts EMPTY (amnesic; paste fresh each session).
    #
    # zenity --text-info --editable: editable text box, prints edited content to
    # stdout. The checkbox gives a confirmation step; Cancel/close returns
    # non-zero so we bail without changing anything. Whether typed, pasted, or
    # decoded from a QR code, the lines take the SAME validated path below.
    prefill="${1:-/dev/null}"
    lines="$($ZEN --text-info --editable --title="Configure a bridge" \
        --width=620 --height=360 --checkbox="Apply and close" \
        --filename="$prefill" 2>/dev/null)" || return 1

    # The Tor bridges QR code (and some "copy your bridges" buttons) hand you the
    # lines as a JSON array, e.g.
    #   ["webtunnel [2001:db8::1]:443 <FP> url=https://h/p ver=0.0.4", "obfs4 ..."]
    # Pasting or scanning that raw fails validation, because [ ] " , are not part
    # of a bridge line. A real bridge line never contains a double-quote, so if the
    # input has any, treat it as that JSON form and pull out each quoted line. The
    # IPv6 [...] INSIDE a line is preserved — only the outer array punctuation is
    # dropped — and JSON-escaped slashes (\/) in url= values are un-escaped.
    lines="$(extract_bridge_lines "$lines")"

    # Pipe to the root helper. It re-validates each line and runs
    # `tor --verify-config` before installing anything. Empty input removes any
    # previously-set bridge (Tor connects direct).
    printf '%s\n' "$lines" | sudo -n aurora-tor-set-bridges 2>/tmp/aurora-bridge-err
    rc=$?
    if [ "$rc" -ne 0 ]; then
        $ZEN --error --title="Bridge rejected" --width=520 \
            --text="AuroraOS did NOT apply the bridge line(s).\n\nEither a line was not a valid bridge, or Tor's own parser rejected it (tor --verify-config). Nothing was changed — Tor is still configured exactly as before.\n\nDetail:\n$(cat /tmp/aurora-bridge-err 2>/dev/null)" \
            2>/dev/null
        rm -f /tmp/aurora-bridge-err
        return 1
    fi
    rm -f /tmp/aurora-bridge-err
    return 0
}

# --- Scan a QR code into the bridge box (Tails-style) -------------------------
# Reads the QR code in the reply from bridges@torproject.org (or from
# bridges.torproject.org) with the webcam and writes the decoded bridge line(s)
# to the file named by $1. Returns 0 if something was decoded, 1 otherwise.
#
# The webcam is OFF by default in AuroraOS (uvcvideo blacklisted). We turn it ON
# only for the scan and OFF again the moment we're done — on success, cancel,
# timeout, or error — so the privacy default is always restored. The decoded
# text is NOT trusted: the caller shows it in the editable box for review and
# passes it through aurora-tor-set-bridges, which validates every line and runs
# `tor --verify-config` before anything is installed. The QR merely saves you
# typing a long obfs4 line by hand.
scan_bridge_qr() {
    out="$1"
    : > "$out"

    if ! command -v zbarcam >/dev/null 2>&1; then
        $ZEN --error --width=480 --title="QR scanning unavailable" \
            --text="The QR scanner (zbar) isn't available in this build, so the webcam scan can't run.\n\nUse \"Paste bridge line(s)\" instead." 2>/dev/null
        return 1
    fi

    $ZEN --question --width=560 --title="Scan a bridge QR code" \
        --ok-label="Turn on camera & scan" --cancel-label="Back" \
        --text="Hold the QR code from the Tor bridges email (the reply from bridges@torproject.org), or from $BRIDGES_URL, up to the webcam.\n\nThe camera is OFF by default for privacy. AuroraOS turns it ON only for this scan and OFF again the instant a code is read.\n\nA preview window opens — line the QR code up inside it. Capturing is automatic; close the preview window to cancel." \
        2>/dev/null || return 1

    if ! sudo -n aurora-camera on >/dev/null 2>&1; then
        $ZEN --error --width=480 --title="Camera error" \
            --text="Could not turn the webcam on." 2>/dev/null
        return 1
    fi

    # The device node appears a moment after the driver loads (udev lag).
    dev=""
    i=0
    while [ "$i" -lt 24 ]; do
        for d in /dev/video0 /dev/video1 /dev/video2 /dev/video3; do
            [ -e "$d" ] && { dev="$d"; break; }
        done
        [ -n "$dev" ] && break
        sleep 0.25; i=$((i + 1))
    done

    cap="$(mktemp /tmp/aurora-qr.XXXXXX)"; chmod 600 "$cap"
    if [ -n "$dev" ]; then
        # QR codes only (-Sdisable then -Sqrcode.enable); --raw => emit just the
        # decoded data with no "QR-Code:" prefix, so the text drops straight into
        # the validator. The preview window lets the user aim.
        zbarcam -q --raw -Sdisable -Sqrcode.enable "$dev" >"$cap" 2>/dev/null &
        zpid=$!
        # Wait up to ~90s for the first decoded symbol to land. Closing the
        # preview window makes zbarcam exit, which ends the wait early (= cancel).
        i=0
        while kill -0 "$zpid" 2>/dev/null; do
            if [ -s "$cap" ]; then
                sleep 0.3   # let the full (possibly multi-line) symbol flush
                break
            fi
            [ "$i" -ge 360 ] && break
            sleep 0.25; i=$((i + 1))
        done
        kill "$zpid" 2>/dev/null
        wait "$zpid" 2>/dev/null
    fi

    # Restore the privacy default immediately: camera OFF again.
    sudo -n aurora-camera off >/dev/null 2>&1 || true

    # A bridges-email QR decodes to Tor's JSON array; convert it to plain bridge
    # lines (same de-JSON the paste path uses) so the review box shows real lines,
    # not ["..."]. Then keep non-blank, de-duplicated lines (a steady QR can be
    # decoded on several frames, emitting the same symbol more than once).
    extract_bridge_lines "$(cat "$cap" 2>/dev/null)" | awk 'NF && !seen[$0]++' >"$out" 2>/dev/null
    rm -f "$cap"

    if [ ! -s "$out" ]; then
        : > "$out"
        if [ -z "$dev" ]; then
            $ZEN --error --width=480 --title="No webcam found" \
                --text="The camera was turned on but no capture device appeared.\n\nCheck that a webcam is connected, or use \"Paste bridge line(s)\" instead." 2>/dev/null
        else
            $ZEN --warning --width=480 --title="No QR code detected" \
                --text="No QR code was read.\n\nTry again with the code held steady and well-lit, or use \"Paste bridge line(s)\" instead." 2>/dev/null
        fi
        return 1
    fi
    return 0
}

# Choose HOW to enter bridge lines (scan a QR code, or paste text), capture them,
# and apply via the validated root helper. Returns 0 if a bridge was applied and
# the user wants to connect now, 1 otherwise (so the loop can decide whether to
# fall through to connect or go back to the menu).
try_configure_bridge() {
    method="$($ZEN --list --radiolist --title="Configure a bridge" \
        --width=600 --height=320 \
        --text="A bridge is an unlisted Tor entry relay — use one where Tor is blocked or censored.\n\nHow do you want to enter your bridge line(s)?" \
        --print-column=2 --hide-column=2 \
        --column="" --column="id" --column="Method" \
        TRUE  scan  "Scan a QR code with the webcam  (e.g. the Tor bridges email)" \
        FALSE paste "Paste bridge line(s) as text" \
        2>/dev/null)" || return 1

    if [ "$method" = "scan" ]; then
        QR="$(mktemp /tmp/aurora-qr-out.XXXXXX)"; chmod 600 "$QR"
        if ! scan_bridge_qr "$QR"; then rm -f "$QR"; return 1; fi
        # Show the decoded lines in the editable box so the user can review (and
        # edit) before applying. Same validated path as pasting.
        configure_bridge "$QR"; rc=$?
        rm -f "$QR"
        [ "$rc" -eq 0 ] || return 1
    else
        # Paste path: tell the user where to GET a bridge line. We copy the
        # bridges website address to the clipboard so it can be pasted into the
        # Unsafe Browser's address bar — and we SAY SO clearly, but ONLY when the
        # copy actually succeeded (otherwise we don't claim it).
        # Try each clipboard tool and FALL THROUGH if it fails — testing only
        # `command -v` (does the binary exist) is not enough: on GNOME, wl-copy
        # exists but FAILS (Mutter doesn't speak the wlr-data-control protocol it
        # uses), and an `if/elif` on existence alone would then never try xclip.
        # Gate each branch on the copy actually succeeding, so xclip (via XWayland,
        # which GNOME does sync to the Wayland clipboard) is reached as a fallback.
        clip=""
        if command -v wl-copy >/dev/null 2>&1 && printf '%s' "$BRIDGES_URL" | wl-copy 2>/dev/null; then clip=1
        elif command -v xclip >/dev/null 2>&1 && printf '%s' "$BRIDGES_URL" | xclip -selection clipboard 2>/dev/null; then clip=1
        elif command -v xsel >/dev/null 2>&1 && printf '%s' "$BRIDGES_URL" | xsel -ib 2>/dev/null; then clip=1; fi
        clipmsg=""
        [ -n "$clip" ] && clipmsg="\n\n📋 The bridges website address ($BRIDGES_URL) was copied to your clipboard — open the Unsafe Browser and paste it into the address bar."
        $ZEN --info --title="Get a bridge line first" --width=600 \
            --text="Get a bridge line (any of):\n  • Open the \"Unsafe Browser\" (clearnet) and visit  $BRIDGES_URL\n  • email bridges@torproject.org from a Gmail/Riseup address\n  • use another device$clipmsg\n\nExample:  obfs4 192.0.2.1:443 <FINGERPRINT> cert=... iat-mode=0\n\nKeep your lines in a text file in ~/Persistent and paste them each session (like Tails). Press OK to open the paste box." \
            2>/dev/null || return 1
        configure_bridge /dev/null || return 1
    fi

    $ZEN --question --title="Bridge set" --width=460 \
        --text="Bridge applied. Tor will use it.\n\nConnect to Tor now?" \
        --ok-label="Connect" --cancel-label="Back to menu" 2>/dev/null
}

while : ; do
    choice="$($ZEN --list --radiolist --title="Connect to Tor" \
        --width=540 --height=320 --text="$INTRO" \
        --print-column=2 --hide-column=2 \
        --column="" --column="id" --column="Option" \
        TRUE  connect "Connect to Tor (direct)" \
        FALSE bridge  "Configure a bridge  (use if Tor is blocked/censored here)" \
        2>/dev/null)" || exit 0   # Cancel/close -> stay offline (still blocked)

    # "bridge" may or may not lead to a connect. try_configure_bridge returns 0
    # only when the user applied a bridge AND chose "Connect now".
    [ "$choice" = "bridge" ] && { try_configure_bridge || continue; }

    # Bootstrap with a pulsing progress dialog. aurora-tor-connect applies the
    # kill-switch (idempotent) and starts Tor with whatever bridge, if any, was
    # configured via the paste box (or none, for a direct connect).
    sudo -n aurora-tor-connect 2>&1 | $ZEN --progress --pulsate --auto-close --no-cancel \
              --title="Connecting to Tor" \
              --text="Establishing a Tor circuit…\n(all other traffic stays blocked until this succeeds)" \
              --width=480 2>/dev/null

    if connected; then
        open_browser   # execs Tor Browser; does not return
    fi

    # Didn't connect: explain and loop back so the user can try a bridge.
    $ZEN --error --width=480 --title="Could not connect to Tor" \
        --text="Tor did not connect.\n\nIf Tor is blocked on this network, choose \"Configure a bridge\" and try again.\n\nYour real IP was NOT exposed — all traffic stayed blocked the whole time." \
        2>/dev/null
done
