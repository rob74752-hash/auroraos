#!/bin/sh
# =============================================================================
# AuroraOS — aurora-set-password  (root; whitelisted for passwordless sudo)
# =============================================================================
# Sets a password for the live user. By default the live user has NO password
# and the screen never auto-locks, so you can't get locked out. Run this only if
# you WANT to be able to lock the screen (Super+L) and unlock it with a password.
#
#   sudo aurora-set-password
# =============================================================================
[ "$(id -u)" -eq 0 ] || { echo "run via: sudo aurora-set-password"; exit 1; }

echo "Set a password for the 'aurora' user (used to unlock the screen)."
echo "Type it twice to confirm. Press Ctrl-C to cancel."
echo

# Restore the terminal's echo and report cleanly if the user interrupts mid-prompt.
trap 'stty echo 2>/dev/null; echo; echo "Cancelled — password unchanged."; exit 1' INT TERM

# We read and confirm the password OURSELVES instead of letting `passwd` exit
# after a single mismatch (which slammed the terminal shut and looked like a
# crash). On a mismatch or an empty entry we say WHY and loop, so the user just
# tries again — nothing is changed until both entries match.
set_ok=0
attempt=0
while [ "$attempt" -lt 5 ]; do
    attempt=$((attempt + 1))

    printf 'New password: '
    stty -echo 2>/dev/null; IFS= read -r p1; stty echo 2>/dev/null; printf '\n'
    printf 'Confirm password: '
    stty -echo 2>/dev/null; IFS= read -r p2; stty echo 2>/dev/null; printf '\n'

    if [ -z "$p1" ]; then
        echo "→ An empty password is not allowed. Let's try again."; echo; continue
    fi
    if [ "$p1" != "$p2" ]; then
        echo "→ The two passwords did NOT match, so nothing was changed. Let's try again."
        echo; continue
    fi

    # chpasswd reads "user:password" from stdin (builtin printf, so the password
    # never appears in the process list). It splits on the FIRST colon only, so
    # colons in the password are fine.
    if printf 'aurora:%s\n' "$p1" | chpasswd 2>/dev/null; then
        set_ok=1
        break
    fi
    echo "→ The system could not set that password. Try a different one."; echo
done

# Don't keep the plaintext around in shell variables once we're done with it.
p1=''; p2=''
trap - INT TERM

if [ "$set_ok" -ne 1 ]; then
    echo
    echo "Password NOT set (cancelled or too many mismatches). The screen still has no lock."
    exit 1
fi

echo
echo "[aurora] Password set successfully."

# A password now exists, so screen locking is safe to re-enable. By default
# AuroraOS sets disable-lock-screen=true (so the no-password user can't get
# locked out); override it for THIS user now that they can actually unlock.
AURORA_UID="$(id -u aurora 2>/dev/null || echo 1000)"
RUNTIME="/run/user/${AURORA_UID}"
if [ -S "${RUNTIME}/bus" ]; then
    runuser -u aurora -- env \
        XDG_RUNTIME_DIR="${RUNTIME}" \
        DBUS_SESSION_BUS_ADDRESS="unix:path=${RUNTIME}/bus" \
        sh -c 'dconf write /org/gnome/desktop/lockdown/disable-lock-screen false
               dconf write /org/gnome/desktop/screensaver/lock-enabled true
               dconf write /org/gnome/desktop/screensaver/idle-activation-enabled true' \
        && echo "[aurora] Screen locking enabled — Super+L locks; unlock with your new password." \
        || echo "[aurora] Password set, but enabling lock failed; log out/in to enable locking."
else
    echo "[aurora] Password set. Log out and back in (or reboot) to enable screen locking."
fi
