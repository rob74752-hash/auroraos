# AuroraOS — R2 credentials for uploading the ISO / publishing updates.
# Copy this file to ".env" and fill in your NEW (rotated) R2 keys.
# ".env" is gitignored — never commit real keys. Keep THIS file as placeholders.
#
#   cp .env.example .env   &&   edit .env
#
# Both r2-upload.py and release.sh auto-load ".env" if it exists.

R2_ACCESS_KEY_ID=your-new-access-key-id
R2_SECRET_ACCESS_KEY=your-new-secret-access-key

# These have working defaults; override only if yours differ.
R2_ACCOUNT_ID=19b9b5fbb35ca9dbc69b99d8531f04de
R2_BUCKET=auroraos-iso
