# AuroraOS is a Linux live-build project: every text file must stay LF so shell
# scripts, hooks, and config never get CRLF-corrupted when cloned on Windows.
* text=auto eol=lf

# Belt-and-suspenders for the executable/script types specifically.
*.sh    text eol=lf
*.chroot text eol=lf
*.binary text eol=lf
*.py    text eol=lf
*.conf  text eol=lf
*.service text eol=lf
